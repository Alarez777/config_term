alias cd="z"
alias l="eza -glha"
alias lss="eza -glh --total-size -s size"
alias ls="eza"
alias cl="clear"
alias treev1="/usr/bin/tree"
alias tree="erd -H --icons -s name"
alias yt="yt-dlp"
alias cat="bat -p"
alias y="yazi"
alias tv="tidy-viewer"
alias subs='fd -e mkv -e mp4 -d 1 | sort | awk '\''{print "mkvmerge -A -D -M --no-chapters --no-global-tags \"" $0 "\" -o \"subs/" $0 ".mka\""}'\'''
alias addsubs='fd -e mkv -e mp4 -d 1 | sort | awk '\''{print "mkvmerge -S \"" $0 "\" \"subs/" $0 ".mka\" -o \"vf/" $0 "\""}'\'''
alias remuxmkv='fd -e mkv -e mp4 -d 1 | sort | awk '\''{print "mkvmerge \"" $0 "\" -o \"vf/" $0 "\""}'\'''
alias ccat='/usr/bin/cat'
alias fdremux='fd -e mkv -d 1 . -x mkvmerge "{}" -o "vf/{}"'
alias fdremuxa='fd -e mkv -d 1 . -x mkvmerge --no-attachments "{}" -o "vf/{}"'
alias nd="neovide"
alias nv="nvim"
alias xpra="GTK_THEME=Adwaita:dark xpra"
alias dmesg='dmesg -T'
alias ddmesg='dmesg'
alias xcpr='xcp -w0 -r'


# Mounts
# 192.168.2.10 (minipc)
alias m10-start='sudo systemctl reset-failed mnt-hdd3tb.mount mnt-10handbrake.mount mnt-ps2rw.mount && sudo systemctl start mnt-hdd3tb.mount mnt-10handbrake.mount mnt-ps2rw.mount'

# 192.168.2.16 (nas)
alias m16-start='sudo systemctl reset-failed mnt-nNAS.mount mnt-nNAS_lectura.mount mnt-nNAS_audio.mount mnt-nNAS_alarez.mount && sudo systemctl start mnt-nNAS.mount mnt-nNAS_lectura.mount mnt-nNAS_audio.mount mnt-nNAS_alarez.mount'

# 192.168.2.19 (laptop)
alias m19-start='sudo systemctl reset-failed mnt-187descargas.mount mnt-187handbrake.mount && sudo systemctl start mnt-187descargas.mount mnt-187handbrake.mount'
#
#todo
alias todo-start='m10-start; m16-start; m19-start'

awkuplo() {
  awk '{for(i=1; i<=NF; i++) $i=toupper(substr($i,1,1)) substr($i,2)}; 1'
}

rcclip() {
    local path
    path=$(/usr/bin/realpath "$1") || return 1
    printf '"%s"' "$path" | /usr/bin/xclip -selection clipboard
    printf '"%s"\n' "$path"
}
rclip() {
    local path
    path=$(/usr/bin/realpath "$1") || return 1

    printf "%s" "$path" | /usr/bin/xclip -selection clipboard
    printf "%s\n" "$path"
}
