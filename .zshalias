alias cd="z"
alias l="eza -glha"
alias lss="eza -glh --total-size -s size"
alias ls="eza"
alias cl="clear"
alias treev1="/usr/bin/tree"
alias tree="erd -H --icons -s name"
alias yt="yt-dlp"
alias cat="bat -p"
alias y="yazi"
alias tv="tidy-viewer"
alias subs='fd -e mkv -e mp4 -d 1 | sort | awk '\''{print "mkvmerge -A -D -M --no-chapters --no-global-tags \"" $0 "\" -o \"subs/" $0 ".mka\""}'\'''
alias addsubs='fd -e mkv -e mp4 -d 1 | sort | awk '\''{print "mkvmerge -S \"" $0 "\" \"subs/" $0 ".mka\" -o \"vf/" $0 "\""}'\'''
alias remuxmkv='fd -e mkv -e mp4 -d 1 | sort | awk '\''{print "mkvmerge \"" $0 "\" -o \"vf/" $0 "\""}'\'''
alias ccat='/usr/bin/cat'
alias fdremux='fd -e mkv -d 1 . -x mkvmerge "{}" -o "vf/{}"'
alias fdremuxa='fd -e mkv -d 1 . -x mkvmerge --no-attachments "{}" -o "vf/{}"'
alias nd="neovide"
alias nv="nvim"
alias xpra="GTK_THEME=Adwaita:dark xpra"
alias dmesg='dmesg -T'
alias ddmesg='dmesg'


awkuplo() {
  awk '{for(i=1; i<=NF; i++) $i=toupper(substr($i,1,1)) substr($i,2)}; 1'
}

rcclip() {
    local path
    path=$(/usr/bin/realpath "$1") || return 1
    printf '"%s"' "$path" | /usr/bin/xclip -selection clipboard
    printf '"%s"\n' "$path"
}
rclip() {
    local path
    path=$(/usr/bin/realpath "$1") || return 1

    printf "%s" "$path" | /usr/bin/xclip -selection clipboard
    printf "%s\n" "$path"
}
